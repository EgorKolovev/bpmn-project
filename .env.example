# ============================================================
# Copy this to `.env` for local development:
#   cp .env.example .env
# Production deployments substitute secrets from `.env.prod`
# via envsubst — see .github/workflows/ci.yml.
# ============================================================

# LLM Backend: "gemini" (direct Google API — recommended) or "polza"
# (OpenAI-compatible proxy via polza.ai).
# Gemini is the default because `thinkingConfig` (needed for good
# BPMN branching on long specs) is not exposed via Polza's surface.
LLM_BACKEND=gemini

# --- Direct Gemini (LLM_BACKEND=gemini) -----------------------------
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-flash-preview
# Tuned defaults — see benchmarking_files/results/PDF_BENCHMARK.md.
# Lower thinking_budget → branching regressions on long specs.
# Higher → MAX_TOKENS truncation risk.
GEMINI_THINKING_BUDGET=4096
GEMINI_MAX_OUTPUT_TOKENS=65536

# --- Polza fallback (LLM_BACKEND=polza) -----------------------------
POLZA_API_KEY=your-polza-api-key-here
POLZA_MODEL=google/gemini-3-flash-preview

# --- Char limits (both backends) ------------------------------------
MAX_MESSAGE_CHARS=20000
REQUEST_CHAR_LIMIT=20000

# --- PostgreSQL -----------------------------------------------------
POSTGRES_USER=bpmn
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=bpmn

# --- Inter-service auth ---------------------------------------------
INTERNAL_API_KEY=change-me-to-a-random-secret

# --- Daily cost cap (local guard) -----------------------------------
DAILY_SPEND_LIMIT_USD=5.0

# --- CORS -----------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com
