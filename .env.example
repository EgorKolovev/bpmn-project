# LLM Backend: "gemini" (direct Google API) or "polza" (polza.ai OpenAI-compatible)
LLM_BACKEND=polza

# Required for LLM_BACKEND=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Required for LLM_BACKEND=polza
POLZA_API_KEY=your-polza-api-key-here
POLZA_MODEL=google/gemini-3.1-flash-lite-preview

# Required: PostgreSQL credentials
POSTGRES_USER=bpmn
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Required: Shared secret for backend <-> ML service auth
INTERNAL_API_KEY=change-me-to-a-random-secret

# Optional
POSTGRES_DB=bpmn
DAILY_SPEND_LIMIT_USD=5.0
CORS_ALLOWED_ORIGINS=https://yourdomain.com
