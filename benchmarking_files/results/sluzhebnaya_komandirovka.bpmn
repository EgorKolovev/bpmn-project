<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Employee" name="Сотрудник">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_7</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_8</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_4</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_5</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Rework_Budget</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_CFO_Head" name="Руководитель ЦФО">
        <bpmn:flowNodeRef>Task_CFO_Head_Approve</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_CEO_Other_CFO" name="СЕО другого ЦФО">
        <bpmn:flowNodeRef>Task_CEO_Approve</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_Accounting" name="Бухгалтерия">
        <bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_2</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_9</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_3</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_10</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_11</bpmn:flowNodeRef><bpmn:flowNodeRef>End_1</bpmn:flowNodeRef></bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Начало">
      <bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:task id="Task_1" name="Согласовать цель, даты, бюджет с руководителем ЦФО">
      <bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_1" name="Командировка от другого ЦФО?">
      <bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_2" name="Согласовать бюджет с СЕО другого ЦФО">
      <bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_3" name="Подать заявление через Nopaper">
      <bpmn:incoming>Flow_4</bpmn:incoming><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:incoming>Flow_23</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_5" name="Рассмотреть заявление и проверить корректность">
      <bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_2" name="Заявление корректно и бюджет в лимите?">
      <bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing><bpmn:outgoing>Flow_9</bpmn:outgoing><bpmn:outgoing>Flow_11</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_4" name="Доработать заявление">
      <bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_10</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_6" name="Купить билеты и забронировать гостиницу через Aviasales">
      <bpmn:incoming>Flow_8</bpmn:incoming><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:outgoing>Flow_14</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_7" name="Поехать в командировку">
      <bpmn:incoming>Flow_14</bpmn:incoming><bpmn:outgoing>Flow_15</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_8" name="Собрать документы (билеты, посадочные, чеки)">
      <bpmn:incoming>Flow_15</bpmn:incoming><bpmn:outgoing>Flow_16</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_9" name="Проверить документы и закрыть командировку">
      <bpmn:incoming>Flow_16</bpmn:incoming><bpmn:outgoing>Flow_17</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_3" name="Опоздание по вине сотрудника?">
      <bpmn:incoming>Flow_17</bpmn:incoming><bpmn:outgoing>Flow_18</bpmn:outgoing><bpmn:outgoing>Flow_19</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_10" name="Возместить стоимость билета компании">
      <bpmn:incoming>Flow_18</bpmn:incoming><bpmn:outgoing>Flow_20</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_11" name="Оплатить новый билет">
      <bpmn:incoming>Flow_19</bpmn:incoming><bpmn:outgoing>Flow_21</bpmn:outgoing></bpmn:task>
    <bpmn:endEvent id="End_1" name="Завершение">
      <bpmn:incoming>Flow_20</bpmn:incoming><bpmn:incoming>Flow_21</bpmn:incoming></bpmn:endEvent>
    <bpmn:task id="Task_CFO_Head_Approve" name="Согласовать бюджет">
      <bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_4" name="Руководитель одобрил?">
      <bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_13</bpmn:outgoing><bpmn:outgoing>Flow_22</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_CEO_Approve" name="Согласовать бюджет">
      </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_5" name="СЕО одобрил?">
      </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Rework_Budget" name="Подобрать более дешёвые варианты">
      <bpmn:incoming>Flow_22</bpmn:incoming><bpmn:outgoing>Flow_23</bpmn:outgoing></bpmn:task>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_3" name="От другого ЦФО" sourceRef="Gateway_1" targetRef="Task_2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">от другого ЦФО</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4" name="От своего ЦФО" sourceRef="Gateway_1" targetRef="Task_3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">от своего ЦФО</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_2" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_3" targetRef="Task_5" />
    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_5" targetRef="Gateway_2" />
    <bpmn:sequenceFlow id="Flow_8" name="Корректно и в лимите" sourceRef="Gateway_2" targetRef="Task_6">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">заявление корректно и бюджет в пределах лимита</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_9" name="Некорректно" sourceRef="Gateway_2" targetRef="Task_4">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">заявление некорректно</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_4" targetRef="Task_3" />
    <bpmn:sequenceFlow id="Flow_11" name="Бюджет превышает лимит" sourceRef="Gateway_2" targetRef="Task_CFO_Head_Approve">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">бюджет превышает лимит</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_CFO_Head_Approve" targetRef="Gateway_4" />
    <bpmn:sequenceFlow id="Flow_13" name="Одобрено" sourceRef="Gateway_4" targetRef="Task_6">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">одобрено</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_6" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_7" targetRef="Task_8" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_8" targetRef="Task_9" />
    <bpmn:sequenceFlow id="Flow_17" sourceRef="Task_9" targetRef="Gateway_3" />
    <bpmn:sequenceFlow id="Flow_18" name="По вине сотрудника" sourceRef="Gateway_3" targetRef="Task_10">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">опоздание по вине сотрудника</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_19" name="Не по вине сотрудника" sourceRef="Gateway_3" targetRef="Task_11">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">опоздание не по вине сотрудника</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_20" sourceRef="Task_10" targetRef="End_1" />
    <bpmn:sequenceFlow id="Flow_21" sourceRef="Task_11" targetRef="End_1" />
    <bpmn:sequenceFlow id="Flow_22" name="Отказано" sourceRef="Gateway_4" targetRef="Task_Rework_Budget">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">отказано</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_23" sourceRef="Task_Rework_Budget" targetRef="Task_3" />
  </bpmn:process>
</bpmn:definitions>