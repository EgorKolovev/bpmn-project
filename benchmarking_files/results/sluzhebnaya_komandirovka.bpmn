<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_Business_Trip" isExecutable="true"><bpmn:laneSet id="LaneSet_1"><bpmn:lane id="Lane_Employee" name="Сотрудник"><bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Agree_CFO</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Other_CFO</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Agree_CEO</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Submit_Nopaper</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Purchase_Travel</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Budget_Limit</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Manager_Approval</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Manager_Decision</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Find_Cheaper</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Trip</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Collect_Docs</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Submit_Docs</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Flight_Fault</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Refund_Company</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Company_Pays</bpmn:flowNodeRef><bpmn:flowNodeRef>End_1</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_Accounting" name="Бухгалтерия"><bpmn:flowNodeRef>Task_Review_App</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_App_Correct</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Check_Docs</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Flight_Issue</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="Start_1" name="Начало"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:task id="Task_Agree_CFO" name="Согласование с руководителем ЦФО"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Other_CFO" name="Другой ЦФО?"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Agree_CEO" name="Согласование с СЕО"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Submit_Nopaper" name="Подача через Nopaper"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Review_App" name="Рассмотрение заявления"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:incoming>Flow_Rework</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_App_Correct" name="Корректно?"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_Rework</bpmn:outgoing><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Purchase_Travel" name="Покупка билетов и бронь"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:incoming>Flow_Cheaper</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Budget_Limit" name="В пределах лимита?"><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_10</bpmn:outgoing><bpmn:outgoing>Flow_11</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Manager_Approval" name="Согласование руководителя"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Manager_Decision" name="Одобрено?"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_Cheaper</bpmn:outgoing><bpmn:outgoing>Flow_13</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Find_Cheaper" name="Подбор дешевых вариантов" /><bpmn:task id="Task_Trip" name="Командировка"><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:outgoing>Flow_14</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Collect_Docs" name="Сбор документов"><bpmn:incoming>Flow_14</bpmn:incoming><bpmn:outgoing>Flow_15</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Submit_Docs" name="Передача в бухгалтерию"><bpmn:incoming>Flow_15</bpmn:incoming><bpmn:outgoing>Flow_16</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Check_Docs" name="Проверка документов"><bpmn:incoming>Flow_16</bpmn:incoming><bpmn:outgoing>Flow_17</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Flight_Issue" name="Опоздание на рейс?"><bpmn:incoming>Flow_17</bpmn:incoming><bpmn:outgoing>Flow_18</bpmn:outgoing><bpmn:outgoing>Flow_19</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:exclusiveGateway id="Gateway_Flight_Fault" name="Вина сотрудника?"><bpmn:incoming>Flow_18</bpmn:incoming><bpmn:outgoing>Flow_20</bpmn:outgoing><bpmn:outgoing>Flow_21</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Refund_Company" name="Возмещение стоимости"><bpmn:incoming>Flow_20</bpmn:incoming><bpmn:outgoing>Flow_22</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Company_Pays" name="Оплата нового билета"><bpmn:incoming>Flow_21</bpmn:incoming><bpmn:outgoing>Flow_23</bpmn:outgoing></bpmn:task><bpmn:endEvent id="End_1" name="Завершение"><bpmn:incoming>Flow_19</bpmn:incoming><bpmn:incoming>Flow_22</bpmn:incoming><bpmn:incoming>Flow_23</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_Agree_CFO" /><bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Agree_CFO" targetRef="Gateway_Other_CFO" /><bpmn:sequenceFlow id="Flow_3" name="Другой ЦФО" sourceRef="Gateway_Other_CFO" targetRef="Task_Agree_CEO"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">другой цфо</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_4" name="Свой ЦФО" sourceRef="Gateway_Other_CFO" targetRef="Task_Submit_Nopaper"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">свой цфо</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_5" sourceRef="Task_Agree_CEO" targetRef="Task_Submit_Nopaper" /><bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Submit_Nopaper" targetRef="Task_Review_App" /><bpmn:sequenceFlow id="Flow_7" sourceRef="Task_Review_App" targetRef="Gateway_App_Correct" /><bpmn:sequenceFlow id="Flow_Rework" name="Некорректно" sourceRef="Gateway_App_Correct" targetRef="Task_Review_App"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">некорректно</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_8" name="Корректно" sourceRef="Gateway_App_Correct" targetRef="Task_Purchase_Travel"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">корректно</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Purchase_Travel" targetRef="Gateway_Budget_Limit" /><bpmn:sequenceFlow id="Flow_10" name="В лимите" sourceRef="Gateway_Budget_Limit" targetRef="Task_Trip"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">в лимите</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_11" name="Превышает" sourceRef="Gateway_Budget_Limit" targetRef="Task_Manager_Approval"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">превышает</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_12" sourceRef="Task_Manager_Approval" targetRef="Gateway_Manager_Decision" /><bpmn:sequenceFlow id="Flow_Cheaper" name="Отказ / Поиск дешевле" sourceRef="Gateway_Manager_Decision" targetRef="Task_Purchase_Travel"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">отказ</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_13" name="Одобрено" sourceRef="Gateway_Manager_Decision" targetRef="Task_Trip"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">одобрено</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_14" sourceRef="Task_Trip" targetRef="Task_Collect_Docs" /><bpmn:sequenceFlow id="Flow_15" sourceRef="Task_Collect_Docs" targetRef="Task_Submit_Docs" /><bpmn:sequenceFlow id="Flow_16" sourceRef="Task_Submit_Docs" targetRef="Task_Check_Docs" /><bpmn:sequenceFlow id="Flow_17" sourceRef="Task_Check_Docs" targetRef="Gateway_Flight_Issue" /><bpmn:sequenceFlow id="Flow_18" name="Опоздание" sourceRef="Gateway_Flight_Issue" targetRef="Gateway_Flight_Fault"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">опоздание</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_19" name="Без опозданий" sourceRef="Gateway_Flight_Issue" targetRef="End_1"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">без опозданий</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_20" name="Вина сотрудника" sourceRef="Gateway_Flight_Fault" targetRef="Task_Refund_Company"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">вина сотрудника</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_21" name="Не вина сотрудника" sourceRef="Gateway_Flight_Fault" targetRef="Task_Company_Pays"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">не вина сотрудника</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_22" sourceRef="Task_Refund_Company" targetRef="End_1" /><bpmn:sequenceFlow id="Flow_23" sourceRef="Task_Company_Pays" targetRef="End_1" /></bpmn:process></bpmn:definitions>