<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_1" isExecutable="true"><bpmn:laneSet id="LaneSet_1"><bpmn:lane id="Lane_Employee" name="Сотрудник"><bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Submit</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_FindCheaper</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Buy</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Trip</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Collect</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_SubmitDocs</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Reimburse</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_CFO_Manager" name="Руководитель ЦФО"><bpmn:flowNodeRef>Task_ApproveCFO</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_OtherCFO</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_CEO_CFO" name="СЕО ЦФО"><bpmn:flowNodeRef>Task_ApproveCEO</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_Accounting" name="Бухгалтерия"><bpmn:flowNodeRef>Task_CheckApp</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Correct</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_CheckDocs</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Delay</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Fault</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_PayNew</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Close</bpmn:flowNodeRef><bpmn:flowNodeRef>End_1</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_Manager" name="Руководитель"><bpmn:flowNodeRef>Gateway_Budget</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_ApproveBudget</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_BudgetDecision</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="Start_1" name="Начало"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:task id="Task_ApproveCFO" name="Согласование с руководителем ЦФО"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_OtherCFO" name="Другой ЦФО?"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_ApproveCEO" name="Согласование с СЕО ЦФО"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Submit" name="Подача заявления через Nopaper"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:incoming>Flow_Rework</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="Task_CheckApp" name="Проверка заявления"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Correct" name="Заявление корректно?"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_Rework</bpmn:outgoing><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:exclusiveGateway id="Gateway_Budget" name="Бюджет в лимите?"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing><bpmn:outgoing>Flow_10</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_ApproveBudget" name="Согласование бюджета"><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:outgoing>Flow_11</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_BudgetDecision" name="Одобрено?"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_FindCheaper" name="Подбор дешевых вариантов"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_13</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Buy" name="Покупка билетов и бронь"><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:outgoing>Flow_14</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Trip" name="Командировка"><bpmn:incoming>Flow_14</bpmn:incoming><bpmn:outgoing>Flow_15</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Collect" name="Сбор документов"><bpmn:incoming>Flow_15</bpmn:incoming><bpmn:outgoing>Flow_16</bpmn:outgoing></bpmn:task><bpmn:task id="Task_SubmitDocs" name="Передача документов"><bpmn:incoming>Flow_16</bpmn:incoming><bpmn:outgoing>Flow_17</bpmn:outgoing></bpmn:task><bpmn:task id="Task_CheckDocs" name="Проверка документов"><bpmn:incoming>Flow_17</bpmn:incoming><bpmn:outgoing>Flow_18</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Delay" name="Опоздание?"><bpmn:incoming>Flow_18</bpmn:incoming><bpmn:outgoing>Flow_19</bpmn:outgoing><bpmn:outgoing>Flow_20</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:exclusiveGateway id="Gateway_Fault" name="Вина сотрудника?"><bpmn:incoming>Flow_19</bpmn:incoming><bpmn:outgoing>Flow_21</bpmn:outgoing><bpmn:outgoing>Flow_22</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Reimburse" name="Возмещение стоимости"><bpmn:incoming>Flow_21</bpmn:incoming><bpmn:outgoing>Flow_23</bpmn:outgoing></bpmn:task><bpmn:task id="Task_PayNew" name="Оплата компанией"><bpmn:incoming>Flow_22</bpmn:incoming><bpmn:outgoing>Flow_24</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Close" name="Закрытие командировки"><bpmn:incoming>Flow_20</bpmn:incoming><bpmn:incoming>Flow_23</bpmn:incoming><bpmn:incoming>Flow_24</bpmn:incoming><bpmn:outgoing>Flow_25</bpmn:outgoing></bpmn:task><bpmn:endEvent id="End_1" name="Завершение"><bpmn:incoming>Flow_25</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_ApproveCFO" /><bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ApproveCFO" targetRef="Gateway_OtherCFO" /><bpmn:sequenceFlow id="Flow_3" name="Да" sourceRef="Gateway_OtherCFO" targetRef="Task_ApproveCEO"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">другой ЦФО</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_4" name="Нет" sourceRef="Gateway_OtherCFO" targetRef="Task_Submit"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">свой ЦФО</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_5" sourceRef="Task_ApproveCEO" targetRef="Task_Submit" /><bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Submit" targetRef="Task_CheckApp" /><bpmn:sequenceFlow id="Flow_7" sourceRef="Task_CheckApp" targetRef="Gateway_Correct" /><bpmn:sequenceFlow id="Flow_Rework" name="Некорректно" sourceRef="Gateway_Correct" targetRef="Task_Submit"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">некорректно</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_8" name="Корректно" sourceRef="Gateway_Correct" targetRef="Gateway_Budget"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">корректно</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_9" name="В лимите" sourceRef="Gateway_Budget" targetRef="Task_Buy"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">в лимите</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_10" name="Превышает" sourceRef="Gateway_Budget" targetRef="Task_ApproveBudget"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">превышает лимит</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_11" sourceRef="Task_ApproveBudget" targetRef="Gateway_BudgetDecision" /><bpmn:sequenceFlow id="Flow_12" name="Отказ" sourceRef="Gateway_BudgetDecision" targetRef="Task_FindCheaper"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">отказ</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_13" sourceRef="Task_FindCheaper" targetRef="Task_Buy" /><bpmn:sequenceFlow id="Flow_14" sourceRef="Task_Buy" targetRef="Task_Trip" /><bpmn:sequenceFlow id="Flow_15" sourceRef="Task_Trip" targetRef="Task_Collect" /><bpmn:sequenceFlow id="Flow_16" sourceRef="Task_Collect" targetRef="Task_SubmitDocs" /><bpmn:sequenceFlow id="Flow_17" sourceRef="Task_SubmitDocs" targetRef="Task_CheckDocs" /><bpmn:sequenceFlow id="Flow_18" sourceRef="Task_CheckDocs" targetRef="Gateway_Delay" /><bpmn:sequenceFlow id="Flow_19" name="Опоздание" sourceRef="Gateway_Delay" targetRef="Gateway_Fault"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">опоздание</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_20" name="Без опозданий" sourceRef="Gateway_Delay" targetRef="Task_Close"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">нет опоздания</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_21" name="Вина сотрудника" sourceRef="Gateway_Fault" targetRef="Task_Reimburse"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">вина сотрудника</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_22" name="Не вина сотрудника" sourceRef="Gateway_Fault" targetRef="Task_PayNew"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">не вина сотрудника</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_23" sourceRef="Task_Reimburse" targetRef="Task_Close" /><bpmn:sequenceFlow id="Flow_24" sourceRef="Task_PayNew" targetRef="Task_Close" /><bpmn:sequenceFlow id="Flow_25" sourceRef="Task_Close" targetRef="End_1" /></bpmn:process></bpmn:definitions>