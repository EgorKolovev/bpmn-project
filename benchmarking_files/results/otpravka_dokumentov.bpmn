<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_Document_Sending" isExecutable="true"><bpmn:laneSet id="LaneSet_1"><bpmn:lane id="Lane_Manager" name="Менеджер"><bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Create_Task</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Clarify_Data</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_Office_Specialist" name="Офис-менеджер / Специалист"><bpmn:flowNodeRef>Task_Check_Data</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Data_Check</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Prepare_Originals</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Collect_Signatures</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Send_Document</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Register_Document</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Archive_Document</bpmn:flowNodeRef><bpmn:flowNodeRef>End_1</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_Legal" name="Юристы"><bpmn:flowNodeRef>Task_Legal_Review</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_Legal_Check</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="Start_1" name="Начало"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:task id="Task_Create_Task" name="Создать задачу в Service Desk"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:incoming>Flow_Clarify_Back</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Check_Data" name="Проверить данные"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Data_Check" name="Результат проверки"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_Incorrect</bpmn:outgoing><bpmn:outgoing>Flow_Legal_Needed</bpmn:outgoing><bpmn:outgoing>Flow_Correct</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Clarify_Data" name="Уточнение данных"><bpmn:incoming>Flow_Incorrect</bpmn:incoming><bpmn:outgoing>Flow_Clarify_Back</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Legal_Review" name="Юридическая проверка"><bpmn:incoming>Flow_Legal_Needed</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Legal_Check" name="Согласовано?"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_Legal_Rejected</bpmn:outgoing><bpmn:outgoing>Flow_Legal_Approved</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Prepare_Originals" name="Подготовить оригиналы"><bpmn:incoming>Flow_Correct</bpmn:incoming><bpmn:incoming>Flow_Legal_Approved</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Collect_Signatures" name="Собрать подписи"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Send_Document" name="Отправить документ"><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Register_Document" name="Регистрация в реестре"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Archive_Document" name="Передать на хранение"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:endEvent id="End_1" name="Завершение"><bpmn:incoming>Flow_Legal_Rejected</bpmn:incoming><bpmn:incoming>Flow_9</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_Create_Task" /><bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Create_Task" targetRef="Task_Check_Data" /><bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Check_Data" targetRef="Gateway_Data_Check" /><bpmn:sequenceFlow id="Flow_Incorrect" name="Данные некорректны" sourceRef="Gateway_Data_Check" targetRef="Task_Clarify_Data"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">данные некорректны</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_Clarify_Back" sourceRef="Task_Clarify_Data" targetRef="Task_Create_Task" /><bpmn:sequenceFlow id="Flow_Legal_Needed" name="Юридические вопросы" sourceRef="Gateway_Data_Check" targetRef="Task_Legal_Review"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">юридические вопросы</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_Correct" name="Данные корректны" sourceRef="Gateway_Data_Check" targetRef="Task_Prepare_Originals"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">данные корректны</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_4" sourceRef="Task_Legal_Review" targetRef="Gateway_Legal_Check" /><bpmn:sequenceFlow id="Flow_Legal_Rejected" name="Не согласовано" sourceRef="Gateway_Legal_Check" targetRef="End_1"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">не согласовано</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_Legal_Approved" name="Согласовано" sourceRef="Gateway_Legal_Check" targetRef="Task_Prepare_Originals"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">согласовано</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_5" sourceRef="Task_Prepare_Originals" targetRef="Task_Collect_Signatures" /><bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Collect_Signatures" targetRef="Task_Send_Document" /><bpmn:sequenceFlow id="Flow_7" sourceRef="Task_Send_Document" targetRef="Task_Register_Document" /><bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Register_Document" targetRef="Task_Archive_Document" /><bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Archive_Document" targetRef="End_1" /></bpmn:process></bpmn:definitions>