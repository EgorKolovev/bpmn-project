<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="Process_1" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Manager" name="Менеджер">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_3</bpmn:flowNodeRef><bpmn:flowNodeRef>End_2</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_OfficeManager_DocSpecialist" name="Офис-менеджер / Специалист по документообороту">
        <bpmn:flowNodeRef>Task_2</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_2</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_5</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_3</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_6</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_7</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_8</bpmn:flowNodeRef><bpmn:flowNodeRef>End_1</bpmn:flowNodeRef></bpmn:lane>
      <bpmn:lane id="Lane_Lawyer" name="Юрист">
        <bpmn:flowNodeRef>Task_4</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_4</bpmn:flowNodeRef></bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_1" name="Начало">
      <bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:task id="Task_1" name="Создать задачу на отправку">
      <bpmn:incoming>Flow_1</bpmn:incoming><bpmn:incoming>Flow_4_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_2" name="Проверить данные">
      <bpmn:incoming>Flow_2</bpmn:incoming><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_1" name="Данные корректны?">
      <bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_3" name="Уточнить данные">
      <bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_4_1</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_2" name="Есть юр. вопросы?">
      <bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_4" name="Проверка юристами">
      <bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_4" name="Юристы согласовали?">
      <bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing><bpmn:outgoing>Flow_10</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_2" name="Задача закрыта">
      <bpmn:incoming>Flow_10</bpmn:incoming></bpmn:endEvent>
    <bpmn:task id="Task_5" name="Подготовить оригиналы документов">
      <bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_11</bpmn:outgoing></bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_3" name="Нужны подписи?">
      <bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing><bpmn:outgoing>Flow_13</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:task id="Task_6" name="Собрать подписи">
      <bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_14</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_7" name="Отправить документ">
      <bpmn:incoming>Flow_13</bpmn:incoming><bpmn:incoming>Flow_14</bpmn:incoming><bpmn:outgoing>Flow_15</bpmn:outgoing></bpmn:task>
    <bpmn:task id="Task_8" name="Зарегистрировать и передать на хранение">
      <bpmn:incoming>Flow_15</bpmn:incoming><bpmn:outgoing>Flow_16</bpmn:outgoing></bpmn:task>
    <bpmn:endEvent id="End_1" name="Завершение">
      <bpmn:incoming>Flow_16</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_1" targetRef="Task_2" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_2" targetRef="Gateway_1" />
    <bpmn:sequenceFlow id="Flow_4" name="Некорректны" sourceRef="Gateway_1" targetRef="Task_3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">данные некорректны</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4_1" sourceRef="Task_3" targetRef="Task_1" />
    <bpmn:sequenceFlow id="Flow_5" name="Корректны" sourceRef="Gateway_1" targetRef="Gateway_2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">данные корректны</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_6" name="Есть юр. вопросы" sourceRef="Gateway_2" targetRef="Task_4">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">есть юридические вопросы</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_7" name="Нет юр. вопросов" sourceRef="Gateway_2" targetRef="Task_5">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">нет юридических вопросов</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_4" targetRef="Gateway_4" />
    <bpmn:sequenceFlow id="Flow_9" name="Согласовано" sourceRef="Gateway_4" targetRef="Task_2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">юристы согласовали</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10" name="Не согласовано" sourceRef="Gateway_4" targetRef="End_2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">юристы не согласовали</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_5" targetRef="Gateway_3" />
    <bpmn:sequenceFlow id="Flow_12" name="Да" sourceRef="Gateway_3" targetRef="Task_6">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">нужны подписи</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13" name="Нет" sourceRef="Gateway_3" targetRef="Task_7">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">подписи не нужны</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_6" targetRef="Task_7" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_7" targetRef="Task_8" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_8" targetRef="End_1" />
  </bpmn:process>
</bpmn:definitions>