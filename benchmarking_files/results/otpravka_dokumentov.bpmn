<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://bpmn.io/schema/bpmn"><bpmn:process id="Process_Outgoing_Docs" isExecutable="true"><bpmn:laneSet id="LaneSet_1"><bpmn:lane id="Lane_Manager" name="Менеджер"><bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_CreateTask</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Clarify</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_Specialist" name="Специалист по документообороту"><bpmn:flowNodeRef>Task_CheckData</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_DataCorrect</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_LegalIssues</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_PrepareOriginals</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_SignaturesNeeded</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_CollectSignatures</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Send</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Register</bpmn:flowNodeRef><bpmn:flowNodeRef>Task_Archive</bpmn:flowNodeRef><bpmn:flowNodeRef>End_1</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="Lane_Legal" name="Юристы"><bpmn:flowNodeRef>Task_LegalReview</bpmn:flowNodeRef><bpmn:flowNodeRef>Gateway_LegalApproved</bpmn:flowNodeRef><bpmn:flowNodeRef>End_Closed</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="Start_1" name="Начало"><bpmn:outgoing>Flow_1</bpmn:outgoing></bpmn:startEvent><bpmn:task id="Task_CreateTask" name="Создать задачу в Service Desk"><bpmn:incoming>Flow_1</bpmn:incoming><bpmn:incoming>Flow_Clarify</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:task id="Task_CheckData" name="Проверить данные"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_DataCorrect" name="Данные корректны?"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_DataIncorrect</bpmn:outgoing><bpmn:outgoing>Flow_DataCorrect</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Clarify" name="Уточнить данные"><bpmn:incoming>Flow_DataIncorrect</bpmn:incoming><bpmn:outgoing>Flow_Clarify</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_LegalIssues" name="Есть юр. вопросы?"><bpmn:incoming>Flow_DataCorrect</bpmn:incoming><bpmn:outgoing>Flow_LegalYes</bpmn:outgoing><bpmn:outgoing>Flow_LegalNo</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_LegalReview" name="Проверка юристами"><bpmn:incoming>Flow_LegalYes</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_LegalApproved" name="Согласовано?"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_LegalApproved</bpmn:outgoing><bpmn:outgoing>Flow_LegalRejected</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_PrepareOriginals" name="Подготовить оригиналы"><bpmn:incoming>Flow_LegalNo</bpmn:incoming><bpmn:incoming>Flow_LegalApproved</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_SignaturesNeeded" name="Нужны подписи?"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_SignYes</bpmn:outgoing><bpmn:outgoing>Flow_SignNo</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_CollectSignatures" name="Собрать подписи"><bpmn:incoming>Flow_SignYes</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Send" name="Отправить документ"><bpmn:incoming>Flow_SignNo</bpmn:incoming><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Register" name="Регистрация в реестре"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Archive" name="Передать на хранение"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:endEvent id="End_1" name="Завершение"><bpmn:incoming>Flow_9</bpmn:incoming></bpmn:endEvent><bpmn:endEvent id="End_Closed" name="Задача закрыта"><bpmn:incoming>Flow_LegalRejected</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_CreateTask" /><bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CreateTask" targetRef="Task_CheckData" /><bpmn:sequenceFlow id="Flow_3" sourceRef="Task_CheckData" targetRef="Gateway_DataCorrect" /><bpmn:sequenceFlow id="Flow_DataIncorrect" name="Данные некорректны" sourceRef="Gateway_DataCorrect" targetRef="Task_Clarify"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">данные некорректны</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_Clarify" sourceRef="Task_Clarify" targetRef="Task_CreateTask" /><bpmn:sequenceFlow id="Flow_DataCorrect" name="Данные корректны" sourceRef="Gateway_DataCorrect" targetRef="Gateway_LegalIssues"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">данные корректны</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_LegalYes" name="Есть вопросы" sourceRef="Gateway_LegalIssues" targetRef="Task_LegalReview"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">есть юридические вопросы</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_LegalNo" name="Вопросов нет" sourceRef="Gateway_LegalIssues" targetRef="Task_PrepareOriginals"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">нет юридических вопросов</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_4" sourceRef="Task_LegalReview" targetRef="Gateway_LegalApproved" /><bpmn:sequenceFlow id="Flow_LegalApproved" name="Согласовано" sourceRef="Gateway_LegalApproved" targetRef="Task_PrepareOriginals"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">согласовано</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_LegalRejected" name="Не согласовано" sourceRef="Gateway_LegalApproved" targetRef="End_Closed"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">не согласовано</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_5" sourceRef="Task_PrepareOriginals" targetRef="Gateway_SignaturesNeeded" /><bpmn:sequenceFlow id="Flow_SignYes" name="Нужны" sourceRef="Gateway_SignaturesNeeded" targetRef="Task_CollectSignatures"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">нужны подписи</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_SignNo" name="Не нужны" sourceRef="Gateway_SignaturesNeeded" targetRef="Task_Send"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">подписи не нужны</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="Flow_6" sourceRef="Task_CollectSignatures" targetRef="Task_Send" /><bpmn:sequenceFlow id="Flow_7" sourceRef="Task_Send" targetRef="Task_Register" /><bpmn:sequenceFlow id="Flow_8" sourceRef="Task_Register" targetRef="Task_Archive" /><bpmn:sequenceFlow id="Flow_9" sourceRef="Task_Archive" targetRef="End_1" /></bpmn:process></bpmn:definitions>