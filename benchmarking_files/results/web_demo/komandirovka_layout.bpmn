ow_1</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Initial_Agreem" name="Согласовано?"><bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_Agreed</bpmn:outgoing><bpmn:outgoing>Flow_Not_Agreed</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:endEvent id="End_Cancelled" name="Поездка не оформляется"><bpmn:incoming>Flow_Not_Agreed</bpmn:incoming></bpmn:endEvent><bpmn:task id="Task_Fill_NP" name="Заполнить заявление в NP"><bpmn:incoming>Flow_Agreed</bpmn:incoming><bpmn:incoming>Flow_Rework</bpmn:incoming><bpmn:outgoing>Flow_3</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Review_NP" name="Проверить и согласовать заявку"><bpmn:incoming>Flow_3</bpmn:incoming><bpmn:outgoing>Flow_4</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_NP_Decision" name="Решение по заявке?"><bpmn:incoming>Flow_4</bpmn:incoming><bpmn:outgoing>Flow_NP_Approved</bpmn:outgoing><bpmn:outgoing>Flow_Rework</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Search_Tickets" name="Подбор билетов и проживания"><bpmn:incoming>Flow_NP_Approved</bpmn:incoming><bpmn:outgoing>Flow_5</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Limit" name="Превышение лимита?"><bpmn:incoming>Flow_5</bpmn:incoming><bpmn:outgoing>Flow_Over_Limit</bpmn:outgoing><bpmn:outgoing>Flow_Within_Limit</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Extra_Approval" name="Дополнительное согласование"><bpmn:incoming>Flow_Over_Limit</bpmn:incoming><bpmn:outgoing>Flow_6</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Booking" name="Оформить покупку и бронирование"><bpmn:incoming>Flow_Within_Limit</bpmn:incoming><bpmn:incoming>Flow_6</bpmn:incoming><bpmn:outgoing>Flow_7</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Order_PerDiem" name="Сформировать приказ и рассчитать суточные"><bpmn:incoming>Flow_7</bpmn:incoming><bpmn:outgoing>Flow_8</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Foreign_Trip" name="Зарубежная поездка?"><bpmn:incoming>Flow_8</bpmn:incoming><bpmn:outgoing>Flow_Foreign_Yes</bpmn:outgoing><bpmn:outgoing>Flow_Foreign_No</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Manual_Adjust" name="Скорректировать сумму вручную"><bpmn:incoming>Flow_Foreign_Yes</bpmn:incoming><bpmn:outgoing>Flow_9</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Calendar_Absence" name="Внести отсутствие в календарь"><bpmn:incoming>Flow_Foreign_No</bpmn:incoming><bpmn:incoming>Flow_9</bpmn:incoming><bpmn:outgoing>Flow_10</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Trip_Execution" name="Командировка"><bpmn:incoming>Flow_10</bpmn:incoming><bpmn:outgoing>Flow_11</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Submit_Report" name="Направить отчет и чеки через SD/NP"><bpmn:incoming>Flow_11</bpmn:incoming><bpmn:outgoing>Flow_12</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Check_Docs" name="Проверить документы"><bpmn:incoming>Flow_12</bpmn:incoming><bpmn:outgoing>Flow_13</bpmn:outgoing></bpmn:task><bpmn:exclusiveGateway id="Gateway_Final_Result" name="Итог проверки?"><bpmn:incoming>Flow_13</bpmn:incoming><bpmn:outgoing>Flow_Reimburse</bpmn:outgoing><bpmn:outgoing>Flow_Deduct</bpmn:outgoing></bpmn:exclusiveGateway><bpmn:task id="Task_Reimburse" name="Возместить расходы"><bpmn:incoming>Flow_Reimburse</bpmn:incoming><bpmn:outgoing>Flow_14</bpmn:outgoing></bpmn:task><bpmn:task id="Task_Deduction" name="Оформить удержание/возврат"><bpmn:incoming>Flow_Deduct</bpmn:incoming><bpmn:outgoing>Flow_15</bpmn:outgoing></bpmn:task><bpmn:endEvent id="End_Success" name="Завершено"><bpmn:incoming>Flow_14</bpmn:incoming><bpmn:incoming>Flow_15</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="Flow_1" sourceRef="Start_1" targetRef="Task_Init_Agreem" /><bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Init_Agreem" targetRef="Gateway_Initial_Agreem" /><bpmn:sequenceFlow id="Flow_Agreed" name="Да" sourceRef="Gateway_Initial_Agreem" targetRef="Task_Fill_NP"><bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">согласо