# ============================================================
# Production environment (generated by CI from .env.prod template
# via envsubst — see .github/workflows/ci.yml prepare-server job).
# ============================================================

# LLM Backend: "polza" (OpenAI-compatible proxy — default, matches
# client infrastructure) or "gemini" (direct Google API).
#
# Polza notes:
#   * Supports reasoning via OpenAI-style `reasoning: {effort: ...}`
#     which we map from `GEMINI_THINKING_BUDGET` automatically inside
#     PolzaBackend (≤ 2048 → low, ≤ 5000 → medium, > 5000 → high).
#   * Requires a funded balance — if you get HTTP 402
#     "credits exhausted", either top up at https://polza.ai/dashboard
#     or flip `LLM_BACKEND=gemini` on the server (no redeploy needed).
LLM_BACKEND=polza

# --- Direct Gemini (LLM_BACKEND=gemini) -----------------------------
GEMINI_API_KEY=${GEMINI_API_KEY}
GEMINI_MODEL=gemini-3-flash-preview
# 4096 thinking budget — tested sweet spot on 13 KB customer PDFs.
# Lower values (≤ 2048) cause branching regressions; higher values
# risk MAX_TOKENS truncation.
GEMINI_THINKING_BUDGET=4096
# 64K output cap — 13 KB specs can produce 30 K+ combined
# thinking + BPMN XML on gemini-3-flash-preview.
GEMINI_MAX_OUTPUT_TOKENS=65536

# --- Polza fallback (LLM_BACKEND=polza) -----------------------------
# Still provisioned so ops can flip LLM_BACKEND=polza without redeploying
# if Gemini direct access becomes unavailable. Note: Polza ignores
# thinkingConfig, so branching quality on long specs will degrade.
POLZA_API_KEY=${POLZA_API_KEY}
POLZA_MODEL=google/gemini-3-flash-preview

# --- Char limits (both backends) ------------------------------------
# Raised 12000 → 20000 after client feedback: 10–13 KB PDF specs were
# getting rejected. Backend and ml must stay in lockstep.
MAX_MESSAGE_CHARS=20000
REQUEST_CHAR_LIMIT=20000

# --- PostgreSQL -----------------------------------------------------
POSTGRES_USER=bpmn
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=bpmn

# --- Inter-service auth ---------------------------------------------
INTERNAL_API_KEY=${INTERNAL_API_KEY}

# --- Daily cost cap (local guard — actual billing from provider) ----
DAILY_SPEND_LIMIT_USD=5.0

# --- CORS -----------------------------------------------------------
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}
