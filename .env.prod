# ============================================================
# Production environment (generated by CI from .env.prod template
# via envsubst — see .github/workflows/ci.yml prepare-server job).
# ============================================================

# LLM Backend: "gemini" (direct Google API — DEFAULT) or "polza"
# (OpenAI-compatible proxy that re-hosts the same Gemini models).
#
# Why Gemini is primary: on Gemini, `thinkingBudget` is a HARD token cap
# on reasoning, so latency is bounded and predictable (~30-60s). On
# Polza the same budget maps to `reasoning.effort`, which has NO token
# cap — gemini-3-flash-preview via Polza reasoned to ~65K tokens / ~218s
# and blew past the HTTP timeout → 502 (prod incident 2026-06-14).
#
# Polza remains a fallback: flip LLM_BACKEND=polza (no redeploy) if
# Gemini access drops. The PolzaBackend now maps budget 4096 → "low"
# effort and is bounded by GEMINI_MAX_OUTPUT_TOKENS, so it won't run away.
LLM_BACKEND=gemini

# --- Direct Gemini (LLM_BACKEND=gemini, primary) --------------------
GEMINI_API_KEY=${GEMINI_API_KEY}
GEMINI_MODEL=gemini-3-flash-preview
# 4096 thinking budget — HARD cap on Gemini. Tested sweet spot on 13 KB
# customer PDFs. Lower (≤ 2048) regresses branching; higher risks
# MAX_TOKENS truncation. On the Polza fallback this maps to "low" effort.
GEMINI_THINKING_BUDGET=4096
# 32K output cap = HARD LATENCY BOUND (~110s worst case at ~300 tok/s).
# Was 65536, which let a runaway reasoning call reach ~218s → HTTP
# timeout → 502. 32K covers thinking + a rich lane diagram with headroom.
GEMINI_MAX_OUTPUT_TOKENS=32768

# --- HTTP timeouts --------------------------------------------------
# Single LLM-call timeout in the ml service (was a hardcoded 180s that
# was SHORTER than a large generation → ReadTimeout → 502).
LLM_HTTP_TIMEOUT=240
# Backend's wait on a single ml /generate or /edit — must exceed
# LLM_HTTP_TIMEOUT so we never cut off an in-flight LLM call.
ML_HTTP_TIMEOUT=300

# --- Polza fallback (LLM_BACKEND=polza) -----------------------------
# Provisioned so ops can flip LLM_BACKEND=polza without redeploying if
# Gemini direct access becomes unavailable. Requires a funded balance —
# HTTP 402 "credits exhausted" means top up at https://polza.ai/dashboard
# (or just stay on Gemini).
POLZA_API_KEY=${POLZA_API_KEY}
POLZA_MODEL=google/gemini-3-flash-preview

# --- Char limits (both backends) ------------------------------------
# Raised 12000 → 20000 after client feedback: 10–13 KB PDF specs were
# getting rejected. Backend and ml must stay in lockstep.
MAX_MESSAGE_CHARS=20000
REQUEST_CHAR_LIMIT=20000

# --- PostgreSQL -----------------------------------------------------
POSTGRES_USER=bpmn
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=bpmn

# --- Inter-service auth ---------------------------------------------
INTERNAL_API_KEY=${INTERNAL_API_KEY}

# --- Daily cost cap (local guard — actual billing from provider) ----
DAILY_SPEND_LIMIT_USD=5.0

# --- CORS -----------------------------------------------------------
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}
