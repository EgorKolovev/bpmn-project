# LLM Backend: "gemini" (direct Google API) or "polza" (polza.ai OpenAI-compatible)
LLM_BACKEND=polza

# Required for LLM_BACKEND=polza
POLZA_API_KEY=${POLZA_API_KEY}
POLZA_MODEL=google/gemini-3.1-flash-lite-preview

# Required: PostgreSQL credentials
POSTGRES_USER=bpmn
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Required: Shared secret for backend <-> ML service auth
INTERNAL_API_KEY=${INTERNAL_API_KEY}

# Optional
POSTGRES_DB=bpmn
DAILY_SPEND_LIMIT_USD=5.0
CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS}
